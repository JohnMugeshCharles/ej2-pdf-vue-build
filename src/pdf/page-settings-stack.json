{"public/index.html":"<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"utf-8\">\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\">\r\n    <link rel=\"icon\" href=\"<%= BASE_URL %>favicon.ico\">\r\n    <title>\r\n        <%= htmlWebpackPlugin.options.title %>\r\n    </title>\r\n    <link href=\"https://cdn.syncfusion.com/ej2/33.1.44/{{theme}}.css\" rel=\"stylesheet\">\r\n    <link href=\"https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css\" rel=\"stylesheet\" />\r\n</head>\r\n\r\n<body>\r\n    <noscript>\r\n        <strong>We're sorry but <%= htmlWebpackPlugin.options.title %> doesn't work properly without JavaScript enabled.\r\n        Please enable it to continue.</strong>\r\n    </noscript>\r\n    <div id=\"app\"></div>\r\n    <style>\r\n            .control-section\r\n            {\r\n                margin-top: 100px;\r\n            }\r\n    </style>\r\n    <!-- built files will be auto injected -->\r\n</body>\r\n\r\n</html>\r\n","src/App.vue":"<template>\r\n  <div class=\"control-section\">\r\n    <div class=\"form-container\">\r\n      <label class=\"e-label\" for=\"ps\">Page Size :</label>\r\n      <ejs-dropdownlist \r\n        id=\"ps\" \r\n        v-model=\"formData.pageSize\" \r\n        :dataSource=\"pageSizeOptions\"\r\n        :fields=\"{ text: 'text', value: 'value' }\"\r\n        floatLabelType=\"Never\"\r\n      ></ejs-dropdownlist>\r\n\r\n      <label class=\"e-label\" for=\"po\">Page Orientation :</label>\r\n      <ejs-dropdownlist \r\n        id=\"po\" \r\n        v-model=\"formData.pageOrientation\" \r\n        :dataSource=\"orientationOptions\"\r\n        :fields=\"{ text: 'text', value: 'value' }\"\r\n        floatLabelType=\"Never\"\r\n      ></ejs-dropdownlist>\r\n\r\n      <label class=\"e-label\" for=\"pm\">Page Margin :</label>\r\n      <ejs-dropdownlist \r\n        id=\"pm\" \r\n        v-model=\"formData.pageMargin\" \r\n        :dataSource=\"marginOptions\"\r\n        :fields=\"{ text: 'text', value: 'value' }\"\r\n        floatLabelType=\"Never\"\r\n      ></ejs-dropdownlist>\r\n\r\n      <label class=\"e-label\" for=\"pr\">Page Rotation :</label>\r\n      <ejs-dropdownlist \r\n        id=\"pr\" \r\n        v-model=\"formData.pageRotation\" \r\n        :dataSource=\"rotationOptions\"\r\n        :fields=\"{ text: 'text', value: 'value' }\"\r\n        floatLabelType=\"Never\"\r\n      ></ejs-dropdownlist>\r\n\r\n      <label class=\"e-label\">Pages Count :</label>\r\n      <div class=\"pages-inline\">\r\n        <ejs-textbox \r\n          id=\"pageCount\" \r\n          v-model=\"formData.pageCount\" \r\n          :readonly=\"true\"\r\n          cssClass=\"page-count-input\"\r\n        ></ejs-textbox>\r\n        <ejs-button id=\"addPage\" @click=\"addPage\" :isPrimary=\"false\">Add Page</ejs-button>\r\n      </div>\r\n    </div>\r\n    <br />\r\n    <br />\r\n    <div>\r\n      <p>\r\n        Click the button to view a PDF document generated by JavaScript PDF Library. Please note that Adobe Reader or its\r\n        equivalent is required to view the resultant document.\r\n      </p>\r\n    </div>\r\n    <div class=\"actions\">\r\n      <ejs-button id=\"normalbtn\" @click=\"createPdf\" :isPrimary=\"true\">Generate PDF</ejs-button>\r\n    </div>\r\n  </div>\r\n</template>\r\n<style scoped>\r\n  .control-section {\r\n    max-width: none;\r\n  }\r\n  .control-section p {\r\n    margin-bottom: 16px;\r\n  }\r\n  .form-container {\r\n    display: grid;\r\n    grid-template-columns: 180px auto;\r\n    column-gap: 12px;\r\n    row-gap: 20px;\r\n    align-items: center;\r\n  }\r\n  .form-label {\r\n    text-align: left;\r\n    white-space: nowrap;\r\n  }\r\n  .form-container ::v-deep(.e-dropdownlist),\r\n  .form-container ::v-deep(.e-input-group) {\r\n    width: 220px !important;\r\n  }\r\n  .pages-inline {\r\n    display: flex;\r\n    gap: 8px;\r\n    align-items: center;\r\n  }\r\n  .pages-inline ::v-deep(.page-count-input) {\r\n    width: 100px;\r\n    text-align: center;\r\n  }\r\n  .actions {\r\n    margin-top: 16px;\r\n  }\r\n</style>\r\n<script lang=\"ts\">\r\nimport { defineComponent, reactive } from 'vue';\r\nimport { TextBoxComponent } from '@syncfusion/ej2-vue-inputs';\r\nimport { DropDownListComponent } from '@syncfusion/ej2-vue-dropdowns';\r\nimport { ButtonComponent } from '@syncfusion/ej2-vue-buttons';\r\nimport {\r\n  PdfDocument,\r\n  PdfPageSettings,\r\n  PdfMargins,\r\n  PdfPen,\r\n  PdfBrush,\r\n  PdfFontFamily,\r\n  PdfFontStyle,\r\n  PdfPageOrientation,\r\n  PdfRotationAngle\r\n} from '@syncfusion/ej2-pdf';\r\n\r\nexport default defineComponent({\r\n  name: 'PageSettingsPdf',\r\n  components: {\r\n    'ejs-textbox': TextBoxComponent,\r\n    'ejs-dropdownlist': DropDownListComponent,\r\n    'ejs-button': ButtonComponent\r\n  },\r\n  setup() {\r\n    const formData = reactive({\r\n      pageSize: 'A4',\r\n      pageOrientation: 'Portrait',\r\n      pageMargin: 'No margin',\r\n      pageRotation: '0',\r\n      pageCount: '1'\r\n    });\r\n\r\n    const pageSizeOptions = [\r\n      { text: 'Letter', value: 'Letter' },\r\n      { text: 'Legal', value: 'Legal' },\r\n      { text: 'A3', value: 'A3' },\r\n      { text: 'A4', value: 'A4' },\r\n      { text: 'A5', value: 'A5' },\r\n      { text: 'B4', value: 'B4' },\r\n      { text: 'B5', value: 'B5' }\r\n    ];\r\n\r\n    const orientationOptions = [\r\n      { text: 'Portrait', value: 'Portrait' },\r\n      { text: 'Landscape', value: 'Landscape' }\r\n    ];\r\n\r\n    const marginOptions = [\r\n      { text: 'No margin', value: 'No margin' },\r\n      { text: 'Small', value: 'Small' },\r\n      { text: 'Large', value: 'Large' }\r\n    ];\r\n\r\n    const rotationOptions = [\r\n      { text: '0', value: '0' },\r\n      { text: '90', value: '90' },\r\n      { text: '180', value: '180' },\r\n      { text: '270', value: '270' }\r\n    ];\r\n\r\n    const addPage = () => {\r\n      const current = parseInt(formData.pageCount || '1', 10);\r\n      formData.pageCount = String(Math.max(1, current + 1));\r\n    };\r\n\r\n    const createPdf = (): void => {\r\n      const ps = formData.pageSize;\r\n      const po = formData.pageOrientation;\r\n      const pm = formData.pageMargin;\r\n      const pr = formData.pageRotation;\r\n      const pageCount = parseInt(formData.pageCount || '1', 10);\r\n      \r\n      const settings = new PdfPageSettings();\r\n      const size = getPageSize(ps);\r\n      settings.size = size as any;\r\n      settings.orientation = po === 'Portrait' ? PdfPageOrientation.portrait : PdfPageOrientation.landscape;\r\n      settings.rotation = getRotationAngle(String(pr));\r\n      settings.margins = new PdfMargins(getMargin(pm));\r\n\r\n      const pdf = new PdfDocument();\r\n      const pen = new PdfPen({ r: 0, g: 0, b: 0 }, 6);\r\n      const lightGreenBrush = new PdfBrush({ r: 144, g: 238, b: 144 });\r\n      const textBrush = new PdfBrush({ r: 0, g: 0, b: 0 });\r\n      const footerFont = pdf.embedFont(PdfFontFamily.helvetica, 16, PdfFontStyle.regular);\r\n\r\n      for (let i = 0; i < pageCount; i++) {\r\n        const page = pdf.addPage(settings);\r\n        const g = page.graphics;\r\n        const client = g.clientSize;\r\n        g.drawRectangle({ x: 0, y: 0, width: client.width, height: client.height }, lightGreenBrush);\r\n        g.drawLine(pen, { x: 0, y: 100 }, { x: Math.min(300, client.width), y: 100 });\r\n        const footerText = `Page ${i + 1} of ${pageCount}`;\r\n        g.drawString(footerText, footerFont, { x: client.width - 150, y: client.height - 40, width: 140, height: 30 }, textBrush);\r\n      }\r\n\r\n      pdf.save('PageSettings.pdf');\r\n      pdf.destroy();\r\n    };\r\n\r\n    const getPageSize = (name: string) => {\r\n      const PAGE_SIZES: Record<string, { width: number; height: number }> = {\r\n        Letter: { width: 612, height: 792 },\r\n        Legal: { width: 612, height: 1008 },\r\n        A3: { width: 842, height: 1191 },\r\n        A4: { width: 595, height: 842 },\r\n        A5: { width: 420, height: 595 },\r\n        B4: { width: 729, height: 1032 },\r\n        B5: { width: 516, height: 729 }\r\n      };\r\n      const key = (name || '').trim();\r\n      return PAGE_SIZES[key] ?? PAGE_SIZES.A4;\r\n    };\r\n\r\n    const getMargin = (name: string): number => {\r\n      const key = (name || '').trim();\r\n      if (key === 'Small') return 20;\r\n      if (key === 'Large') return 40;\r\n      return 0;\r\n    };\r\n\r\n    const getRotationAngle = (deg: string): PdfRotationAngle => {\r\n      switch ((deg || '').trim()) {\r\n        case '90':\r\n          return PdfRotationAngle.angle90;\r\n        case '180':\r\n          return PdfRotationAngle.angle180;\r\n        case '270':\r\n          return PdfRotationAngle.angle270;\r\n        default:\r\n          return PdfRotationAngle.angle0;\r\n      }\r\n    };\r\n\r\n    return {\r\n      formData,\r\n      pageSizeOptions,\r\n      orientationOptions,\r\n      marginOptions,\r\n      rotationOptions,\r\n      addPage,\r\n      createPdf\r\n    };\r\n  }\r\n});\r\n</script>","dependencies":"{\"vue\":\"3.3.4\",\"@syncfusion/ej2-base\":\"*\",\"@syncfusion/ej2-vue-base\":\"*\",\"@syncfusion/ej2-inputs\":\"*\",\"@syncfusion/ej2-vue-inputs\":\"*\",\"@syncfusion/ej2-dropdowns\":\"*\",\"@syncfusion/ej2-vue-dropdowns\":\"*\",\"@syncfusion/ej2-buttons\":\"*\",\"@syncfusion/ej2-vue-buttons\":\"*\",\"@syncfusion/ej2-compression\":\"*\",\"markdown-spellcheck\":\"^1.3.1\",\"@syncfusion/ej2-pdf\":\"*\"}","src/main.js":"import { createApp } from 'vue'\nimport App from './App.vue'\ncreateApp(App).mount('#app')"}